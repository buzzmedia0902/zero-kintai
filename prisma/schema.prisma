generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("EMPLOYEE") // ADMIN | EMPLOYEE
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attendances            Attendance[]
  attendanceCorrections  AttendanceCorrection[]
  leaveRequests          LeaveRequest[]
  leaveBalances          LeaveBalance[]
  approvedCorrections    AttendanceCorrection[] @relation("ApprovedCorrections")
  approvedLeaveRequests  LeaveRequest[]         @relation("ApprovedLeaveRequests")
}

model Attendance {
  id         String    @id @default(cuid())
  userId     String
  date       String    // YYYY-MM-DD
  clockIn    DateTime
  clockOut   DateTime?
  breakStart DateTime?
  breakEnd   DateTime?
  note       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  corrections AttendanceCorrection[]

  @@unique([userId, date])
}

model AttendanceCorrection {
  id                String    @id @default(cuid())
  attendanceId      String
  userId            String
  correctedClockIn  DateTime
  correctedClockOut DateTime?
  reason            String
  status            String    @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedById      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy User?      @relation("ApprovedCorrections", fields: [approvedById], references: [id])
}

model LeaveRequest {
  id           String   @id @default(cuid())
  userId       String
  leaveType    String   // PAID | SUBSTITUTE | SPECIAL | ABSENCE
  startDate    String   // YYYY-MM-DD
  endDate      String   // YYYY-MM-DD
  reason       String?
  status       String   @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy User? @relation("ApprovedLeaveRequests", fields: [approvedById], references: [id])
}

model LeaveBalance {
  id         String   @id @default(cuid())
  userId     String
  fiscalYear Int      // e.g. 2026
  totalDays  Float    @default(0)
  usedDays   Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fiscalYear])
}
